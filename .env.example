ENV=development
SECRET_KEY=change-me-with-strong-random-secret
DEBUG=true
TIME_ZONE=America/Bogota
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
DRF_THROTTLE_ANON=60/min
DRF_THROTTLE_USER=180/min
DRF_THROTTLE_AUTH_LOGIN=10/min
DRF_THROTTLE_AUTH_REGISTER=5/min
JWT_ROTATE_REFRESH_TOKENS=true
JWT_BLACKLIST_AFTER_ROTATION=true
JWT_ACCESS_MINUTES=20
AUTH_REFRESH_COOKIE=habit_tracker_refresh
AUTH_REFRESH_COOKIE_PATH=/api/token/refresh/
AUTH_REFRESH_COOKIE_MAX_AGE=604800
# Local development can use Lax; production should use Strict with HTTPS.
AUTH_REFRESH_COOKIE_SAMESITE=Lax
AUTH_REFRESH_COOKIE_SECURE=false
LEADERBOARD_MAX_USERS=200
LEADERBOARD_CACHE_TTL=600
LEADERBOARD_TOP_RESULTS=20
LEADERBOARD_LEADERS_LIMIT=10
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self'
CSP_STYLE_SRC='self' 'unsafe-inline'
CSP_IMG_SRC='self' data: blob:
CSP_CONNECT_SRC='self'
CSP_FONT_SRC='self' data:

# Production only
DATABASE_URL=postgresql://habit_user:habit_pass@localhost:5432/habit_tracker
REDIS_URL=redis://localhost:6379/1
